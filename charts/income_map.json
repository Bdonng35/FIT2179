{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 320,
  "projection": {
  "type": "mercator",
  "center": [109.5, 4.0],
  "scale": 1850
},
  "layer": [
    {
      "data": {
        "sphere": true
      },
      "mark": {
        "type": "geoshape",
        "fill": "#dcebf7"
      }
    },
    {
      "data": {
        "url": "../data/malaysia_map.topojson",
        "format": {
          "type": "topojson",
          "feature": "ne_10m_graticules_1"
        }
      },
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 0.45,
        "opacity": 0.45
      }
    },
    {
      "data": {
        "url": "../data/malaysia_map.topojson",
        "format": {
          "type": "topojson",
          "feature": "ne_10m_admin_0_countries"
        }
      },
      "transform": [
        {
          "filter": "datum.properties.ADM0_A3 != 'MYS'"
        }
      ],
      "mark": {
        "type": "geoshape",
        "fill": "#d7d9dd",
        "stroke": "#90979f",
        "strokeWidth": 0.7
      }
    },
    {
      "data": {
        "url": "../data/malaysia_map.topojson",
        "format": {
          "type": "topojson",
          "feature": "malaysia.state"
        }
      },
      "transform": [
        {
          "calculate": "datum.properties.name",
          "as": "state"
        },
        {
          "lookup": "state",
          "from": {
            "data": {
              "url": "../data/hh_income_state.csv"
            },
            "key": "state",
            "fields": ["date", "income_median"]
          }
        },
        {
          "filter": "datum.date == '2022-01-01'"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#fffdf8",
        "strokeWidth": 1.1
      },
      "encoding": {
        "color": {
          "field": "income_median",
          "type": "quantitative",
          "title": "Median Household Income (RM), 2022",
          "scale": {
            "scheme": "tealblues",
            "domain": [3500, 10500]
          },
          "legend": {
            "gradientLength": 220
          }
        },

        "tooltip": [
          {
            "field": "state",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "income_median",
            "type": "quantitative",
            "title": "Median Income (RM)",
            "format": ",.0f"
          }
        ]
      }
    }
  ],
  "config": {
    "background": "#fffdf8",
    "view": {
      "stroke": null
    }
  }
}